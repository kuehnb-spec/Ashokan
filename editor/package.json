{
  "name": "ashokan-editor",
  "version": "0.1.0",
  "private": true,
  "description": "ProseMirror-based WYSIWYG editing core for Ashokan",
  "type": "module",
  "scripts": {
    "build": "esbuild src/editor.js --bundle --format=iife --global-name=AshokanBundle --outfile=../Ashokan/Resources/editor.js --minify=false",
    "watch": "npm run build -- --watch"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "prosemirror-commands": "^1.6.0",
    "prosemirror-dropcursor": "^1.8.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.23.0",
    "prosemirror-schema-list": "^1.4.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.6.1",
    "prosemirror-view": "^1.36.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
